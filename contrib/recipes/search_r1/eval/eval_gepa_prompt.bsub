#!/bin/bash
#BSUB -J eval_searchr1_%EVAL_TAG%_m%METRIC_CALLS%
#BSUB -G grp_runtime
#BSUB -q normal
#BSUB -n 72
#BSUB -R "span[hosts=1] rusage[mem=128GB]"
#BSUB -gpu "num=8:mode=shared:j_exclusive=yes:gmodel=NVIDIAH10080GBHBM3"
#BSUB -o /proj/inf-scaling/zwhong/projs/asmi/agent-lightning/contrib/recipes/search_r1/outputs/eval_%EVAL_TAG%_m%METRIC_CALLS%.%J.out
#BSUB -e /proj/inf-scaling/zwhong/projs/asmi/agent-lightning/contrib/recipes/search_r1/outputs/eval_%EVAL_TAG%_m%METRIC_CALLS%.%J.err

# Full-test evaluation of a GEPA-optimized prompt on test.parquet (hotpotqa, 7405 samples).
# Generated by monitor_best_and_eval.py — do not submit manually.
# Placeholders: %EVAL_TAG%, %METRIC_CALLS%, %PROMPT_PATH%, %ADDR_FILE%

set -euo pipefail

PPLRL=/proj/inf-scaling/zwhong/projs/asmi/prompt-policy-rl
PYTHON=${PPLRL}/.venv/bin/python
RECIPE=/proj/inf-scaling/zwhong/projs/asmi/agent-lightning/contrib/recipes/search_r1
ADDR_FILE=${RECIPE}/outputs/%ADDR_FILE%
PROMPT_PATH=%PROMPT_PATH%
VLLM_PORT=8101
VLLM_ADDR_FILE=${RECIPE}/outputs/vllm_gepa_eval_addr.txt
# Eval job reserves 8 GPUs; replicate Qwen2.5-3B with tp=1 dp=8 (matches train_gepa.bsub).
VLLM_DATA_PARALLEL_SIZE=${VLLM_DATA_PARALLEL_SIZE:-8}
GEPA_ROLLOUT_CONCURRENCY=${GEPA_ROLLOUT_CONCURRENCY:-8}

set -a
# shellcheck source=/dev/null
source "${RECIPE}/.env"
set +a

export PYTHONNOUSERSITE=1 PYTHONUNBUFFERED=1
CACHE_ROOT=/proj/inf-scaling/zwhong/.cache
export HF_HOME="${CACHE_ROOT}/huggingface"
export TRITON_CACHE_DIR="${CACHE_ROOT}/triton_gepa_eval"
export XDG_CACHE_HOME="${CACHE_ROOT}/xdg_gepa_eval"
export PYTHONPATH=/proj/inf-scaling/zwhong/projs/asmi/agent-lightning:${RECIPE}/scripts:${PYTHONPATH:-}

mkdir -p "${TRITON_CACHE_DIR}" "${XDG_CACHE_HOME}"

echo "Waiting for BM25 retrieval server at ${ADDR_FILE} ..."
until [ -f "${ADDR_FILE}" ]; do sleep 5; done
export RETRIEVAL_SERVER_URL=$(cat "${ADDR_FILE}")
echo "Retrieval server ready: ${RETRIEVAL_SERVER_URL}"

rm -f "${VLLM_ADDR_FILE}"
echo "Starting vLLM OpenAI server on port ${VLLM_PORT} (tp=1 dp=${VLLM_DATA_PARALLEL_SIZE}) ..."
${PYTHON} -m vllm.entrypoints.openai.api_server \
    --model Qwen/Qwen2.5-3B-Instruct \
    --served-model-name Qwen/Qwen2.5-3B-Instruct \
    --host 0.0.0.0 \
    --port "${VLLM_PORT}" \
    --tensor-parallel-size 1 \
    --data-parallel-size "${VLLM_DATA_PARALLEL_SIZE}" \
    --gpu-memory-utilization 0.85 \
    --max-model-len 8192 \
    --disable-log-requests &
VLLM_PID=$!

cleanup() {
    kill "${VLLM_PID}" 2>/dev/null || true
    rm -f "${VLLM_ADDR_FILE}"
}
trap cleanup EXIT

echo "Waiting for vLLM health check ..."
for _ in $(seq 1 120); do
    if curl -sf "http://127.0.0.1:${VLLM_PORT}/health" >/dev/null 2>&1; then
        echo "http://127.0.0.1:${VLLM_PORT}/v1" > "${VLLM_ADDR_FILE}"
        break
    fi
    if ! kill -0 "${VLLM_PID}" 2>/dev/null; then
        echo "vLLM server exited unexpectedly" >&2
        exit 1
    fi
    sleep 5
done

if [ ! -f "${VLLM_ADDR_FILE}" ]; then
    echo "Timed out waiting for vLLM server" >&2
    exit 1
fi

export OPENAI_API_BASE=$(cat "${VLLM_ADDR_FILE}")
export OPENAI_API_KEY=${OPENAI_API_KEY:-token-abc123}
export GEPA_ROLLOUT_CONCURRENCY=${GEPA_ROLLOUT_CONCURRENCY}

GEPA_RUN_DIR=${RECIPE}/outputs/gepa_qwen25_3b
if [ -f "${GEPA_RUN_DIR}/wandb_eval_run_id.txt" ]; then
  export WANDB_RUN_ID=$(tr -d '[:space:]' < "${GEPA_RUN_DIR}/wandb_eval_run_id.txt")
  export WANDB_RESUME=allow
  echo "Resuming WandB eval run ${WANDB_RUN_ID} from ${GEPA_RUN_DIR}/wandb_eval_run_id.txt"
fi

echo "Evaluating prompt ${PROMPT_PATH} on full test.parquet (metric_calls=%METRIC_CALLS%, rollout_concurrency=${GEPA_ROLLOUT_CONCURRENCY}) ..."
cd "${RECIPE}"
${PYTHON} scripts/eval_gepa_prompt.py "${PROMPT_PATH}" --metric-calls %METRIC_CALLS%
