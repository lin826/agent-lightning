#!/bin/bash
#BSUB -J train_searchr1_qwen25_3b_rewrite_em
#BSUB -G grp_preemptable
#BSUB -q preemptable
#BSUB -n 64
#BSUB -R "span[hosts=1] rusage[mem=128GB]"
#BSUB -gpu "num=8:mode=shared:j_exclusive=yes:gmodel=NVIDIAH10080GBHBM3"
#BSUB -o /proj/inf-scaling/zwhong/projs/asmi/agent-lightning/contrib/recipes/search_r1/outputs/train_qwen25_3b_rewrite_em.%J.out
#BSUB -e /proj/inf-scaling/zwhong/projs/asmi/agent-lightning/contrib/recipes/search_r1/outputs/train_qwen25_3b_rewrite_em.%J.err

# GRPO training for Search-R1 with Qwen2.5-3B-Instruct: question-rewrite + pure-EM reward.
# Variant B (rewrite + pure-EM reward). Uses serve/serve_retrieval_rewrite_em.bsub.

set -euo pipefail

PPLRL=/proj/inf-scaling/zwhong/projs/asmi/prompt-policy-rl
PYTHON=${PPLRL}/.venv/bin/python
RAY=${PPLRL}/.venv/bin/ray
RECIPE=/proj/inf-scaling/zwhong/projs/asmi/agent-lightning/contrib/recipes/search_r1
ADDR_FILE=${RECIPE}/outputs/bm25_server_addr_rewrite_em.txt

set -a
# shellcheck source=/dev/null
source "${RECIPE}/.env"
set +a

export PYTHONNOUSERSITE=1 PYTHONUNBUFFERED=1
# Caches on /proj (not /u/zwhong home -- avoids home-dir quota).
CACHE_ROOT=/proj/inf-scaling/zwhong/.cache
export HF_HOME="${CACHE_ROOT}/huggingface"
export TRITON_CACHE_DIR="${CACHE_ROOT}/triton"
export XDG_CACHE_HOME="${CACHE_ROOT}/xdg"
export PYTHONPATH=/proj/inf-scaling/zwhong/projs/asmi/agent-lightning:${RECIPE}/scripts:${PYTHONPATH:-}

CKPT_ROOT="/proj/inf-scaling/zwhong/projs/asmi/agent-lightning/contrib/recipes/search_r1/checkpoints/searchr1_qwen3_8b_rewrite_em"
STEP=$(tr -d '[:space:]' < "${CKPT_ROOT}/latest_checkpointed_iteration.txt")
export VERL_RESUME_FROM_PATH="${CKPT_ROOT}/global_step_${STEP}"
export WANDB_RUN_ID=$(tr -d '[:space:]' < "${CKPT_ROOT}/wandb_run_id.txt")
export WANDB_RESUME=allow
echo "Resuming from ${VERL_RESUME_FROM_PATH}, WandB run ${WANDB_RUN_ID}"

echo "Waiting for retrieval server at ${ADDR_FILE} ..."
until [ -f "${ADDR_FILE}" ]; do sleep 5; done
export RETRIEVAL_SERVER_URL=$(cat "${ADDR_FILE}")
echo "Retrieval server ready: ${RETRIEVAL_SERVER_URL}"

${RAY} stop -v --force --grace-period 60 || true
env RAY_DEBUG=legacy HYDRA_FULL_ERROR=1 VLLM_USE_V1=1 \
    ${RAY} start --head --dashboard-host=0.0.0.0

cd "${RECIPE}"
${PYTHON} scripts/train_search_r1_agent.py qwen3_8b_rewrite_em
