# One GEPA chunk ≈ one GRPO global_step (2760 metric calls by default).
# Re-submit after each chunk completes to continue from gepa_state.bin.
#
#   SERVE_JID=$(bsub < serve/serve_retrieval_gepa.bsub | sed -n 's/.*Job <\([0-9]*\)>.*/\1/p')
#   bsub -w "started(${SERVE_JID})" < train/run_gepa_chunked.bsub

set -euo pipefail

SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
export GEPA_CHUNK_METRIC_CALLS=${GEPA_CHUNK_METRIC_CALLS:-2760}
exec bash "${SCRIPT_DIR}/train_gepa.bsub"
