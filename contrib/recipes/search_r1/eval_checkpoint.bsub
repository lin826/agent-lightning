#!/bin/bash
#BSUB -J eval_searchr1_%EVAL_TAG%_step%STEP%
#BSUB -G grp_preemptable
#BSUB -q preemptable
#BSUB -n 64
#BSUB -R "span[hosts=1] rusage[mem=128GB]"
#BSUB -gpu "num=8:mode=shared:j_exclusive=yes:gmodel=NVIDIAH10080GBHBM3"
#BSUB -o /proj/inf-scaling/zwhong/projs/asmi/agent-lightning/contrib/recipes/search_r1/outputs/eval_%EVAL_TAG%_step%STEP%.%J.out
#BSUB -e /proj/inf-scaling/zwhong/projs/asmi/agent-lightning/contrib/recipes/search_r1/outputs/eval_%EVAL_TAG%_step%STEP%.%J.err

# Full-test evaluation of a Search-R1 checkpoint on test.parquet (hotpotqa only, 7405 samples).
# This script is generated by monitor_best_and_eval.py — do not submit manually.
# Arguments are filled via sed: %EVAL_TAG%, %CONF%, %STEP%, %CKPT_PATH%, %ADDR_FILE%

set -euo pipefail

PPLRL=/proj/inf-scaling/zwhong/projs/asmi/prompt-policy-rl
PYTHON=${PPLRL}/.venv/bin/python
RAY=${PPLRL}/.venv/bin/ray
RECIPE=/proj/inf-scaling/zwhong/projs/asmi/agent-lightning/.claude/worktrees/feature+searchr1-qwen25-repro-qwen3-eval/contrib/recipes/search_r1
ADDR_FILE=${RECIPE}/outputs/%ADDR_FILE%

set -a
# shellcheck source=/dev/null
source "${RECIPE}/.env"
set +a

export PYTHONNOUSERSITE=1 PYTHONUNBUFFERED=1
export HF_HOME=/proj/inf-scaling/zwhong/.cache/huggingface
export TRITON_CACHE_DIR=${RECIPE}/outputs/triton
export XDG_CACHE_HOME=${RECIPE}/outputs/xdg
export PYTHONPATH=/proj/inf-scaling/zwhong/projs/asmi/agent-lightning/.claude/worktrees/feature+searchr1-qwen25-repro-qwen3-eval:${PYTHONPATH:-}

echo "Waiting for retrieval server at ${ADDR_FILE} ..."
until [ -f "${ADDR_FILE}" ]; do sleep 5; done
export RETRIEVAL_SERVER_URL=$(cat "${ADDR_FILE}")
echo "Retrieval server ready: ${RETRIEVAL_SERVER_URL}"

${RAY} stop -v --force --grace-period 60 || true
env RAY_DEBUG=legacy HYDRA_FULL_ERROR=1 VLLM_USE_V1=1 \
    ${RAY} start --head --dashboard-host=0.0.0.0

cd "${RECIPE}"
${PYTHON} eval_search_r1_agent.py %CONF% %CKPT_PATH% --step %STEP%
