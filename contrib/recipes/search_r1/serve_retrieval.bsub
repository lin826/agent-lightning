#!/bin/bash
#BSUB -J serve_bm25_searchr1
#BSUB -G grp_runtime
#BSUB -q normal
#BSUB -n 64
#BSUB -R "span[hosts=1] rusage[mem=512GB]"
#BSUB -gpu "num=8:mode=shared:j_exclusive=yes:gmodel=NVIDIAH10080GBHBM3"
#BSUB -o /proj/inf-scaling/zwhong/projs/asmi/agent-lightning/contrib/recipes/search_r1/outputs/serve_bm25.%J.out
#BSUB -e /proj/inf-scaling/zwhong/projs/asmi/agent-lightning/contrib/recipes/search_r1/outputs/serve_bm25.%J.err

# BM25 retrieval server for search_r1 training.
# Mirrors job 1666214 (serve_torch_bm25) but writes its address to the
# search_r1 outputs/ directory so the training job can discover it.

set -euo pipefail

PPLRL=/proj/inf-scaling/zwhong/projs/asmi/prompt-policy-rl
PYTHON=${PPLRL}/.venv/bin/python
WIKI=/proj/inf-scaling/zwhong/projs/asmi/code/dsl-agent/dspy_tutorial/wiki2017
RECIPE=/proj/inf-scaling/zwhong/projs/asmi/agent-lightning/contrib/recipes/search_r1
ADDR_FILE=${RECIPE}/outputs/bm25_server_addr.txt

export PYTHONNOUSERSITE=1 PYTHONUNBUFFERED=1
export HF_HOME=/u/zwhong/.cache/huggingface
export TRITON_CACHE_DIR=${PPLRL}/tmp/triton
export XDG_CACHE_HOME=${PPLRL}/tmp/xdg

mkdir -p "${TRITON_CACHE_DIR}" "${XDG_CACHE_HOME}" "${RECIPE}/outputs"

# Remove stale addr file so the training job does not connect to a dead server.
rm -f "${ADDR_FILE}"

cd "${PPLRL}"

# Server writes ADDR_FILE only after the index is fully loaded.
${PYTHON} scripts/torch_bm25_server.py \
    --wiki-dir "${WIKI}" --bm25-device cuda --addr-file "${ADDR_FILE}" &
SRV_PID=$!

# Keepalive prevents the cluster from reaping idle GPUs between queries.
${PYTHON} scripts/gpu_keepalive.py &
KEEP_PID=$!

trap "kill ${KEEP_PID} 2>/dev/null; rm -f ${ADDR_FILE}" EXIT

wait ${SRV_PID}
