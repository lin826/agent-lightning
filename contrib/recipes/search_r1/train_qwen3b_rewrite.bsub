#!/bin/bash
#BSUB -J train_searchr1_qwen25_3b_rewrite
#BSUB -G grp_runtime
#BSUB -q normal
#BSUB -n 64
#BSUB -R "span[hosts=1] rusage[mem=128GB]"
#BSUB -gpu "num=8:mode=shared:j_exclusive=yes:gmodel=NVIDIAH10080GBHBM3"
#BSUB -o /proj/inf-scaling/zwhong/projs/asmi/agent-lightning/contrib/recipes/search_r1/outputs/train_qwen3_8b_rewrite.%J.out
#BSUB -e /proj/inf-scaling/zwhong/projs/asmi/agent-lightning/contrib/recipes/search_r1/outputs/train_qwen3_8b_rewrite.%J.err

# GRPO training for Search-R1 with Qwen2.5-3B-Instruct: question-rewrite + shaped reward.
# Variant C (rewrite + shaped reward). Uses serve_retrieval_rewrite.bsub.

set -euo pipefail

PPLRL=/proj/inf-scaling/zwhong/projs/asmi/prompt-policy-rl
PYTHON=${PPLRL}/.venv/bin/python
RAY=${PPLRL}/.venv/bin/ray
RECIPE=/proj/inf-scaling/zwhong/projs/asmi/agent-lightning/.claude/worktrees/feature+searchr1-qwen25-repro-qwen3-eval/contrib/recipes/search_r1
ADDR_FILE=${RECIPE}/outputs/bm25_server_addr_rewrite.txt

set -a
# shellcheck source=/dev/null
source "${RECIPE}/.env"
set +a

export PYTHONNOUSERSITE=1 PYTHONUNBUFFERED=1
# Caches on /proj (not /u/zwhong home -- avoids home-dir quota).
CACHE_ROOT=/proj/inf-scaling/zwhong/.cache
export HF_HOME="${CACHE_ROOT}/huggingface"
export TRITON_CACHE_DIR="${CACHE_ROOT}/triton"
export XDG_CACHE_HOME="${CACHE_ROOT}/xdg"
export PYTHONPATH=/proj/inf-scaling/zwhong/projs/asmi/agent-lightning/.claude/worktrees/feature+searchr1-qwen25-repro-qwen3-eval:${PYTHONPATH:-}

echo "Waiting for retrieval server at ${ADDR_FILE} ..."
until [ -f "${ADDR_FILE}" ]; do sleep 5; done
export RETRIEVAL_SERVER_URL=$(cat "${ADDR_FILE}")
echo "Retrieval server ready: ${RETRIEVAL_SERVER_URL}"

${RAY} stop -v --force --grace-period 60 || true
env RAY_DEBUG=legacy HYDRA_FULL_ERROR=1 VLLM_USE_V1=1 \
    ${RAY} start --head --dashboard-host=0.0.0.0

cd "${RECIPE}"
${PYTHON} train_search_r1_agent.py qwen3_8b_rewrite
