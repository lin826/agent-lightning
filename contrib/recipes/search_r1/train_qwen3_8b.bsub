#!/bin/bash
#BSUB -J train_searchr1_qwen3_8b
#BSUB -G grp_runtime
#BSUB -q normal
#BSUB -n 56
#BSUB -R "span[hosts=1] rusage[mem=512GB]"
#BSUB -gpu "num=8:mode=shared:j_exclusive=yes:gmodel=NVIDIAH10080GBHBM3"
#BSUB -o /proj/inf-scaling/zwhong/projs/asmi/agent-lightning/contrib/recipes/search_r1/outputs/train_qwen3_8b.%J.out
#BSUB -e /proj/inf-scaling/zwhong/projs/asmi/agent-lightning/contrib/recipes/search_r1/outputs/train_qwen3_8b.%J.err

# GRPO training for Search-R1 with Qwen3-8B.
# Uses its own dedicated retrieval server (serve_retrieval_qwen3.bsub).

set -euo pipefail

PPLRL=/proj/inf-scaling/zwhong/projs/asmi/prompt-policy-rl
PYTHON=${PPLRL}/.venv/bin/python
RAY=${PPLRL}/.venv/bin/ray
RECIPE=/proj/inf-scaling/zwhong/projs/asmi/agent-lightning/contrib/recipes/search_r1
ADDR_FILE=${RECIPE}/outputs/bm25_server_addr_qwen3.txt

set -a
# shellcheck source=/dev/null
source "${RECIPE}/.env"
set +a

export PYTHONNOUSERSITE=1 PYTHONUNBUFFERED=1
export HF_HOME=/u/zwhong/.cache/huggingface
export TRITON_CACHE_DIR=${RECIPE}/outputs/triton_qwen3
export XDG_CACHE_HOME=${RECIPE}/outputs/xdg_qwen3
export PYTHONPATH=/proj/inf-scaling/zwhong/projs/asmi/agent-lightning:${PYTHONPATH:-}

mkdir -p "${TRITON_CACHE_DIR}" "${XDG_CACHE_HOME}"

echo "Waiting for retrieval server at ${ADDR_FILE} ..."
until [ -f "${ADDR_FILE}" ]; do sleep 5; done
export RETRIEVAL_SERVER_URL=$(cat "${ADDR_FILE}")
echo "Retrieval server ready: ${RETRIEVAL_SERVER_URL}"

${RAY} stop -v --force --grace-period 60 || true
env RAY_DEBUG=legacy HYDRA_FULL_ERROR=1 VLLM_USE_V1=1 \
    ${RAY} start --head --dashboard-host=0.0.0.0

cd "${RECIPE}"
${PYTHON} train_search_r1_agent.py qwen3_8b
